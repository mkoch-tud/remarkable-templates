        {"main15Y": "main14Y + lineHeight"},
        {"main16Y": "main15Y + lineHeight"},
        {"main17Y": "main16Y + lineHeight"},
        {"footerStartY": "main17Y"},
        {"halfContent": "contentWidth / 2"},
        {"textMargin": 120},
        {"halfLine": "lineHeight / 2"}
    ],
    "items": [
        {
            "type": "text",
            "text": "Date          /          /",
            "fontSize": 42,
            "position": {
                "x": "marginLeft + contentWidth - 400",
                "y": "headerY"
            }
        },
        {
            "type": "text",
            "text": "Purpose of meeting",
            "fontSize": 32,
            "fontWeight": "bold",
            "position": {
                "x": "marginLeft",
                "y": "headerLineY + halfLine"
            }
        },
        {
            "type": "text",
            "text": "Questions",
            "fontSize": 32,
            "fontWeight": "bold",
            "position": {
                "x": "marginLeft",
                "y": "mainStartY + halfLine"
            }
        },
        {
            "type": "text",
            "text": "Notes",
            "fontSize": 32,
            "fontWeight": "bold",
            "position": {
                "x": "halfContent + textMargin",
                "y": "mainStartY + halfLine"
            }
        },
        {
            "type": "text",
            "text": "Decisions",
            "fontSize": 32,
            "fontWeight": "bold",
            "position": {
                "x": "marginLeft",
                "y": "footerStartY + halfLine"
            }
        },
        {
            "type": "text",
            "text": "Action Items",
            "fontSize": 32,
            "fontWeight": "bold",
            "position": {
                "x": "halfContent + textMargin",
                "y": "footerStartY + halfLine"
            }
        },
        {
            "type": "path",
            "data": [
                "M", "marginLeft", "headerLineY",
                "L", "marginLeft + contentWidth", "headerLineY"
            ],
            "strokeWidth": 3
        },

        {
            "type": "path",
            "data": [
                "M", "marginLeft", "firstLineY",
                "L", "marginLeft + contentWidth", "firstLineY"
            ],
            "strokeWidth": 1,
            "opacity": 0.3
        },
